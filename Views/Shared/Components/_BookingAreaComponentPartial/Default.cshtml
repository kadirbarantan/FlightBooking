    </div><!-- /bk-panel -->
</div><!-- /bk-wrap -->

<script>
    // ── Tab switching ──
    function bkSwitchTab(btn, id) {
        document.querySelectorAll('.bk-tab-btn').forEach(b => b.classList.remove('active'));
        document.querySelectorAll('.bk-tab-content').forEach(c => c.classList.remove('active'));
        btn.classList.add('active');
        document.getElementById('bk-' + id).classList.add('active');
    }

    // ── Journey type ──
    function bkJourneyType(btn, type) {
        document.querySelectorAll('.bk-jt-btn').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        var returnCard = document.getElementById('bk-return-card');
        var returnInput = document.getElementById('bk-return');
        if (type === 'oneway') {
            returnCard.style.opacity = '0.45';
            returnCard.style.pointerEvents = 'none';
            returnInput.disabled = true;
        } else {
            returnCard.style.opacity = '1';
            returnCard.style.pointerEvents = 'auto';
            returnInput.disabled = false;
        }
    }

    // ── Swap routes ──
    function bkSwapRoutes() {
        var f = document.getElementById('bk-from');
        var t = document.getElementById('bk-to');
        var tmp = f.value; f.value = t.value; t.value = tmp;
    }

    // ── Pax counter ──
    var bkPaxData = { adult: 1, child: 0, infant: 0, cabin: 'Ekonomi' };

    function bkTogglePax() {
        var dd = document.getElementById('bk-pax-dropdown');
        dd.classList.toggle('open');
    }

    function bkClosePax(e) {
        e.stopPropagation();
        document.getElementById('bk-pax-dropdown').classList.remove('open');
        bkUpdatePaxDisplay();
    }

    function bkPax(e, type, delta) {
        e.stopPropagation();
        var min = (type === 'adult') ? 1 : 0;
        bkPaxData[type] = Math.max(min, Math.min(9, bkPaxData[type] + delta));
        document.getElementById('bk-' + type + '-val').textContent = bkPaxData[type];
    }

    function bkCabin(btn, name) {
        document.querySelectorAll('.bk-cabin-btn').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        bkPaxData.cabin = name;
    }

    function bkUpdatePaxDisplay() {
        var total = bkPaxData.adult + bkPaxData.child + bkPaxData.infant;
        var label = total + ' Yolcu · ' + bkPaxData.cabin;
        document.getElementById('bk-pax-display').textContent = label;
    }

    document.addEventListener('click', function (e) {
        var card = document.getElementById('bk-pax-card');
        var dd = document.getElementById('bk-pax-dropdown');
        if (dd && dd.classList.contains('open') && !card.contains(e.target)) {
            dd.classList.remove('open');
            bkUpdatePaxDisplay();
        }
    });

    // ── Promo code ──
    function bkTogglePromo() {
        var row = document.getElementById('bk-promo-row');
        row.classList.toggle('open');
        if (row.classList.contains('open')) {
            document.getElementById('bk-promo-input').focus();
        }
    }

    // ── Query method (Seyahatlerim) ──
    function bkQMethod(btn, id) {
        document.querySelectorAll('#bk-trips .bk-qm-btn').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        var forms = ['bkq-pnr', 'bkq-ticket', 'bkq-email'];
        forms.forEach(function (f) {
            var el = document.getElementById(f);
            if (el) el.classList.remove('active');
        });
        var target = document.getElementById('bkq-' + id);
        if (target) target.classList.add('active');
    }

    // ── Check-in method ──
    function bkCIMethod(btn, id) {
        document.querySelectorAll('#bk-checkin .bk-qm-btn').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        ['ci-pnr', 'ci-ticket'].forEach(function (f) {
            var el = document.getElementById(f);
            if (el) el.classList.remove('active');
        });
        var target = document.getElementById(id);
        if (target) target.classList.add('active');
    }

    // ── Flight status method ──
    function bkFSMethod(btn, id) {
        document.querySelectorAll('#bk-status .bk-qm-btn').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        ['fs-flightno', 'fs-route'].forEach(function (f) {
            var el = document.getElementById(f);
            if (el) el.classList.remove('active');
        });
        var target = document.getElementById(id);
        if (target) target.classList.add('active');
    }
</script>
